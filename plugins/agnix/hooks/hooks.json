{
  "description": "agnix plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'var f=require(\"fs\"),p=JSON.parse(f.readFileSync(\"package.json\",\"utf8\"));delete p.devDependencies;f.writeFileSync(\"package.json\",JSON.stringify(p,null,2)+\"\\n\")' && bun install 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/lint-config-file.ts"
          }
        ]
      }
    ]
  }
}
