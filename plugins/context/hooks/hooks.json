{
  "description": "context plugin hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/redirect-claude-md-edit.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      }
    ]
  }
}
