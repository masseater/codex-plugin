{
  "description": "context plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'var f=require(\"fs\"),p=JSON.parse(f.readFileSync(\"package.json\",\"utf8\"));delete p.devDependencies;f.writeFileSync(\"package.json\",JSON.stringify(p,null,2)+\"\\n\")' && bun install"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/redirect-claude-md-edit.ts"
          }
        ]
      }
    ]
  }
}
