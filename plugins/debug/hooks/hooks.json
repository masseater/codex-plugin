{
  "description": "debug plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/session-start.ts"
          }
        ]
      }
    ]
  }
}
