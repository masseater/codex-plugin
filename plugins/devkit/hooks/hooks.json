{
  "description": "devkit plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'var f=require(\"fs\"),p=JSON.parse(f.readFileSync(\"package.json\",\"utf8\"));delete p.devDependencies;f.writeFileSync(\"package.json\",JSON.stringify(p,null,2)+\"\\n\")' && bun install 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/block-deny-command.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/standards-audit.ts"
          }
        ]
      }
    ]
  }
}
