{
  "description": "discord-notify plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/create-thread.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/send-discord.ts"
          }
        ]
      }
    ]
  }
}
