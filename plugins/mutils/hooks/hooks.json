{
  "description": "mutils plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'var f=require(\"fs\"),p=JSON.parse(f.readFileSync(\"package.json\",\"utf8\"));delete p.devDependencies;f.writeFileSync(\"package.json\",JSON.stringify(p,null,2)+\"\\n\")' && bun install 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "./hooks/entry/check-context-version.ts"
          },
          {
            "type": "command",
            "command": "./hooks/entry/workspace-id-persist.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/suggest-todo.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/block-unsafe-type-assertion.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/block-husky-bypass.ts"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/suggest-plan-enhancer.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoWrite|TaskCreate|TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/task-history.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/send-notification.ts"
          },
          {
            "type": "command",
            "command": "./hooks/entry/suggest-todo.ts"
          }
        ]
      }
    ]
  }
}
