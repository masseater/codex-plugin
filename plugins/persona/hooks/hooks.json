{
  "description": "persona plugin hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/announce-persona.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/inject-persona.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/on-exit-plan.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/cleanup-persona.ts"
          }
        ]
      }
    ]
  }
}
