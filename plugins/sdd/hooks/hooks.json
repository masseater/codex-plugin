{
  "description": "sdd plugin hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/block-archived-edit.ts"
          },
          {
            "type": "command",
            "command": "./hooks/codex-hook-runner.sh ./hooks/entry/require-phase-status.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      }
    ]
  }
}
