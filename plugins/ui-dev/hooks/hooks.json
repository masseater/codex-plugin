{
  "description": "ui-dev plugin hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*figma.*__get_screenshot",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/entry/redirect-figma-screenshot.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/install-deps.sh"
          }
        ]
      }
    ]
  }
}
